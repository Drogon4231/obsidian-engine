# ═══════════════════════════════════════════════════════════════════════════════
# Obsidian Engine — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys.
# Get each key from the URLs listed below.
#
# REQUIRED keys are needed for basic operation.
# OPTIONAL keys enable additional features.
# ═══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Anthropic (Claude) — LLM for all text generation
# Get yours: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ElevenLabs — Text-to-Speech narration
# Get yours: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=

# Narrator voice ID (default: "George" — deep, authoritative)
# Browse voices: https://elevenlabs.io/voice-library
# Leave blank to use default
ELEVENLABS_NARRATOR_VOICE_ID=
ELEVENLABS_QUOTE_VOICE_ID=

# fal.ai — AI image generation
# Get yours: https://fal.ai/dashboard/keys
FAL_KEY=
FAL_API_KEY=

# Pexels — Stock footage
# Get yours: https://www.pexels.com/api/new/
PEXELS_API_KEY=

# ── OPTIONAL: Database ────────────────────────────────────────────────────────

# Supabase — Video metadata storage & analytics
# Get yours: https://supabase.com → Project Settings → API
SUPABASE_URL=
SUPABASE_KEY=

# ── OPTIONAL: YouTube Upload ─────────────────────────────────────────────────

# YouTube Data API v3 — Automated upload
# Setup guide: https://developers.google.com/youtube/v3/getting-started
# 1. Create OAuth 2.0 credentials in Google Cloud Console
# 2. Save as client_secrets.json in project root
# 3. Run the pipeline once — it will open a browser for OAuth consent
# 4. Token saved to youtube_token.json (gitignored)
#
# For headless/Docker deployment, set this to the JSON content of youtube_token.json:
YOUTUBE_TOKEN_JSON=

# ── OPTIONAL: Notifications ──────────────────────────────────────────────────

# Telegram — Pipeline status notifications
# Setup: Message @BotFather on Telegram → /newbot → get token
# Chat ID: Message @userinfobot → get your chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord — Pipeline status notifications (legacy, optional)
DISCORD_WEBHOOK_URL=

# ── OPTIONAL: Competitive Intelligence ────────────────────────────────────────

# YouTube Data API key (for competitor channel analysis)
# Get yours: https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=

# ── INTERNAL (usually don't change) ──────────────────────────────────────────

# Allow HTTP for local OAuth flow
OAUTHLIB_INSECURE_TRANSPORT=1

# Unbuffered Python output (better Docker logging)
PYTHONUNBUFFERED=1
